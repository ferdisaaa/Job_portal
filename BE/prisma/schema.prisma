// ============================================================
//  PRISMA SCHEMA — KerjaGo Database
//  Provider: PostgreSQL (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Model: Job ──────────────────────────────────────────────
model Job {
  id           String   @id @default(uuid()) @map("id")
  title        String   @map("title")
  company      String   @map("company")
  location     String   @map("location")
  type         String   @map("type")
  salary       String   @map("salary")
  description  String   @map("description")
  distance     Int?     @map("distance")
  education    String?  @map("education")
  requirements String[] @map("requirements")
  created_at   DateTime @default(now()) @map("created_at")

  @@map("jobs")
}

// ─── Model: User ─────────────────────────────────────────────
model User {
  id         String   @id @default(uuid()) @map("id")
  name       String   @map("name")
  email      String   @unique @map("email")
  password   String   @map("password")
  role       String   @default("user") @map("role")
  created_at DateTime @default(now()) @map("created_at")

  @@map("users")
}
